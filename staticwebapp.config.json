          "clientIdSettingName": "AZURE_CLIENT_ID",
          "clientSecretSettingName": "AZURE_CLIENT_SECRET"
        }
      }
    }
  },
  "globalHeaders": {
    "Content-Security-Policy": "default-src 'self'; connect-src 'self' https://aplicacionbackweb-d5bxb7bvhefjgcd0.canadacentral-01.azurewebsites.net;",
    "Access-Control-Allow-Origin": "https://aplicacionbackweb-d5bxb7bvhefjgcd0.canadacentral-01.azurewebsites.net"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
